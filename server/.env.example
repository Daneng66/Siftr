# Local development config. Copy to `.env` (gitignored) and adjust.
# These are only needed for local dev — the Docker image sets its own values.

# Where Siftr stores photos, thumbnails, and the SQLite db.
# Defaults to /data (correct in the container, wrong on Windows).
DATA_DIR=./data

# Path to the czkawka_cli binary. Omit if it's already on your PATH
# (the default is the bare name "czkawka_cli").
# CZKAWKA_BIN=C:\tools\czkawka_cli.exe

# Path to the exiftool binary. Omit if it's on your PATH.
# EXIFTOOL_BIN=C:\tools\exiftool.exe

# czkawka similarity preset for near-duplicate images (Minimal..VeryHigh).
# CZKAWKA_IMAGE_PRESET=High

# Also run the perceptual similar-image pass (off by default).
# DEDUP_SIMILAR=true

# PORT=8080
